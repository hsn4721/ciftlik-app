<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>ÇiftlikPRO</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>ÇiftlikPRO</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<!-- Konum izni — yalnızca uygulama kullanıldığında. `Always` izinleri
		     kaldırıldı (Apple Guideline 5.1.1(iv): app gerçekten background
		     location kullanmadıkça istenmemeli). -->
		<key>NSLocationWhenInUseUsageDescription</key>
		<string>Konumunuza göre hava durumu bilgisi göstermek için konum iznine ihtiyaç duyulmaktadır.</string>
		<!-- Background fetch için arka plan modu (hava durumu sync).
		     `remote-notification` kaldırıldı — firebase_messaging kullanılmıyor,
		     yalnızca local notifications var. Bu sayede push entitlement
		     gereksinimi de düşüyor. -->
		<key>UIBackgroundModes</key>
		<array>
			<string>fetch</string>
		</array>
		<!-- Kamera ve fotoğraf (hayvan fotoğrafı için) -->
		<key>NSCameraUsageDescription</key>
		<string>Hayvan fotoğrafı eklemek için kamera iznine ihtiyaç duyulmaktadır.</string>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>Hayvan fotoğrafı seçmek için galeri iznine ihtiyaç duyulmaktadır.</string>
		<key>NSPhotoLibraryAddUsageDescription</key>
		<string>Çekilen hayvan fotoğraflarını galeriye kaydetmek için izin gerekir.</string>
		<!-- App Transport Security — HTTPS-only.
		     NSExceptionDomains kaldırıldı: Firebase/Google domain'leri zaten
		     HTTPS kullanıyor, exception açıklaması App Review'da soru işareti
		     yaratıyordu. -->
		<key>NSAppTransportSecurity</key>
		<dict>
			<key>NSAllowsArbitraryLoads</key>
			<false/>
		</dict>
		<!-- url_launcher için izinli URL şemaları. https/http kaldırıldı
		     (default izinli, canOpenURL ile sorgulanmaz). -->
		<key>LSApplicationQueriesSchemes</key>
		<array>
			<string>mailto</string>
			<string>tel</string>
			<string>itms-apps</string>
		</array>
		<!-- Face ID için açıklama (local_auth biyometri) -->
		<key>NSFaceIDUsageDescription</key>
		<string>Uygulamayı hızlı ve güvenli açmak için Face ID kullanılır.</string>
		<key>UIApplicationSceneManifest</key>
		<dict>
			<key>UIApplicationSupportsMultipleScenes</key>
			<false/>
			<key>UISceneConfigurations</key>
			<dict>
				<key>UIWindowSceneSessionRoleApplication</key>
				<array>
					<dict>
						<key>UISceneClassName</key>
						<string>UIWindowScene</string>
						<key>UISceneConfigurationName</key>
						<string>flutter</string>
						<key>UISceneDelegateClassName</key>
						<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
						<key>UISceneStoryboardFile</key>
						<string>Main</string>
					</dict>
				</array>
			</dict>
		</dict>
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
		</array>
		<key>UIStatusBarHidden</key>
		<true/>
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<false/>
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
	</dict>
</plist>
